# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_PRIVATE_KEY: Google Sheets Service Account private key for full read/write database actions.
# Format starts with "-----BEGIN PRIVATE KEY-----" and ends with "-----END PRIVATE KEY-----".
GOOGLE_PRIVATE_KEY="YOUR_GOOGLE_PRIVATE_KEY"

# GOOGLE_SERVICE_ACCOUNT_EMAIL: Email of the Google Cloud Service Account with permissions to access sheets.
GOOGLE_SERVICE_ACCOUNT_EMAIL="YOUR_GOOGLE_SERVICE_ACCOUNT_EMAIL"

# GOOGLE_SPREADSHEET_ID: The default master spreadsheet ID used for reading and writing database tables.
GOOGLE_SPREADSHEET_ID="YOUR_GOOGLE_SPREADSHEET_ID"

